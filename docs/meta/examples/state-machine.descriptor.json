{
  "version": 1,
  "concepts": {
    "State": {
      "attributes": {
        "isInitial": "bool",
        "isFinal": "bool"
      },
      "pointers": {
        "entry": "Action",
        "run": "Action",
        "exit": "Action"
      }
    },
    "Transition": {
      "pointers": {
        "src": "State",
        "dst": "State",
        "event": "Event",
        "guard": "Guard",
        "action": "Action"
      }
    },
    "Machine": {
      "contains": {
        "Action": "*",
        "Constraint": "*",
        "Event": "*",
        "Guard": "*",
        "State": "*"
      },
      "attributes": {
        "description": "string"
      }
    },
    "Event": {},
    "Guard": {},
    "Action": {
      "attributes": {
        "body": "string"
      }
    },
    "Constraint": {
      "attributes": {
        "body": "string",
        "kind": {
          "type": "enum",
          "values": ["safety", "goal"]
        }
      }
    },
    "Variable": {
      "attributes": {
        "type": {
          "type": "enum",
          "values": ["float", "string"]
        }
      },
      "contains": {
        "Machine": "*"
      }
    },
    "File": {
      "contains": {
        "Machine": "*"
      }
    }
  }
}
