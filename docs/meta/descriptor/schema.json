{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webgme.org/schemas/webdot/meta-descriptor/v1.json",
  "title": "MetaDescriptor",
  "description": "Compact metamodel (webdot v1). Pointer-first: no connection/relationship layer — src/dst are ordinary pointers. Contains and sets share the same member-rule shape (optional global + per-type members).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "concepts"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "concepts": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/conceptName" },
      "additionalProperties": { "$ref": "#/$defs/conceptBody" }
    }
  },
  "$defs": {
    "conceptName": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z][A-Za-z0-9_]*)*$",
      "description": "Host: bare name. Library: FullyQualifiedName (Library.Concept)."
    },
    "cardinality": {
      "type": "string",
      "minLength": 1,
      "description": "Count constraint. Shorthand: *, +, ?. Exact non-negative integer n. Inclusive range min..max (e.g. 0..1, 2..5).",
      "pattern": "^(\\*|\\+|\\?|\\d+|\\d+\\.\\.\\d+)$"
    },
    "attributeType": {
      "type": "string",
      "enum": ["string", "float", "enum", "bool", "asset", "integer"]
    },
    "attributeMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "$ref": "#/$defs/attributeType" },
        "hidden": { "type": "boolean" },
        "readOnly": { "type": "boolean" },
        "values": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "default": {}
      }
    },
    "attributeDef": {
      "oneOf": [{ "$ref": "#/$defs/attributeType" }, { "$ref": "#/$defs/attributeMeta" }]
    },
    "typeRef": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z][A-Za-z0-9_]*)*$"
    },
    "typeRefOrList": {
      "oneOf": [
        { "$ref": "#/$defs/typeRef" },
        { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/typeRef" } }
      ]
    },
    "membersMap": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/conceptName" },
      "additionalProperties": { "$ref": "#/$defs/cardinality" },
      "description": "Per-type member cardinality (child type or set member type → constraint string)."
    },
    "memberRule": {
      "description": "Mirrors MetaLang contains[global] / set name[global] -> members. Flat map when no global limit.",
      "oneOf": [
        { "$ref": "#/$defs/membersMap" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["members"],
          "properties": {
            "global": { "$ref": "#/$defs/cardinality" },
            "members": { "$ref": "#/$defs/membersMap" }
          }
        }
      ]
    },
    "conceptBody": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extends": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z][A-Za-z0-9_]*)*$"
        },
        "contains": { "$ref": "#/$defs/memberRule" },
        "pointers": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/typeRefOrList" }
        },
        "sets": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/memberRule" }
        },
        "attributes": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/attributeDef" }
        }
      }
    }
  }
}
